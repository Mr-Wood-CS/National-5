<mxfile>
  <diagram id="flowchart-symbols" name="Flowchart Symbols">
    <mxGraphModel dx="393" dy="355" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="520" math="0" shadow="0">
      <root>
        <mxCell id="0" />
