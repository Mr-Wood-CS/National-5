        <mxCell id="4yHliKWaJuixyEqNFP5F-1" value="&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=quicksand&quot; face=&quot;quicksand&quot; style=&quot;font-size: 18px;&quot;&gt;Start/End&lt;/font&gt;" style="strokeWidth=1;html=1;shape=mxgraph.flowchart.terminator;whiteSpace=wrap;" vertex="1" parent="1">
